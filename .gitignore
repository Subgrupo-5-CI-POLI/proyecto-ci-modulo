# =============================================================================
#  .gitignore - Archivos y carpetas que NO se suben al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencias de Node.js
# -----------------------------------------------------------------------------
# node_modules es regenerable con "npm install" y pesa mucho.
# Nunca se sube a git. Dentro de Docker se reinstala automáticamente.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Variables de entorno (pueden contener secretos)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env

# -----------------------------------------------------------------------------
# Archivos de log
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Archivos del sistema operativo
# -----------------------------------------------------------------------------
.DS_Store              # macOS
Thumbs.db              # Windows
desktop.ini            # Windows
*.swp                  # vim
*.swo

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Archivos temporales y de build
# -----------------------------------------------------------------------------
tmp/
temp/
dist/
build/
coverage/

# -----------------------------------------------------------------------------
# Docker - volúmenes locales (si los hubiera)
# -----------------------------------------------------------------------------
docker-volumes/
